{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stage 0 - Preprocessing",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "python_scripts\\orchestrator.py",
        "--data-dir",
        "data",
        "--output-dir",
        "outputs",
        "--skip-forecasting"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1",
          "MPLBACKEND": "Agg"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Stage 1 - MLP Screening 1step",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "python_scripts\\orchestrator.py",
        "--data-dir",
        "data",
        "--output-dir",
        "outputs",
        "--forecasting-from-derived",
        "--forecasting-stage",
        "stage_1_mlp_screening_1step"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1",
          "MPLBACKEND": "Agg"
        }
      },
      "problemMatcher": []
    },
