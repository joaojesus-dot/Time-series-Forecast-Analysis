  ],
  "inputs": [
    {
      "id": "stage2OneStepRun",
      "type": "promptString",
      "description": "Path to archived Stage 2 1step run folder",
      "default": "outputs\\chinese_boiler_dataset\\history\\PASTE_1STEP_RUN_FOLDER"
    },
    {
      "id": "stage2ThreeMinuteRun",
