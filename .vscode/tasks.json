      "args": [
        "python_scripts\\plots.py",
        "--compare-archived-stages",
        "--stage-a-run",
        "${input:stage2OneStepRun}",
        "--stage-a-label",
        "Stage 2 - 1step baseline MLP",
        "--stage-b-run",
        "${input:stage2ThreeMinuteRun}",
        "--stage-b-label",
        "Stage 2 - 3min baseline MLP",
        "--output-dir",
        "outputs\\chinese_boiler_dataset\\current\\stage_2_horizon_impact\\comparison"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1",
          "MPLBACKEND": "Agg"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Stage 3 - Univariate MLP 3min",
