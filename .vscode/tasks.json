      "args": [
        "python_scripts\\orchestrator.py",
        "--data-dir",
        "data",
        "--output-dir",
        "outputs",
        "--forecasting-from-derived",
        "--forecasting-stage",
        "stage_2_baseline_3min_top3"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONUNBUFFERED": "1",
