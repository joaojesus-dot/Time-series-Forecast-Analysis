{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run orchestrator",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/python_scripts/orchestrator.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--data-dir",
        "${workspaceFolder}/data",
        "--output-dir",
        "${workspaceFolder}/outputs"
      ]
    },
    {
      "name": "Run orchestrator without forecasting",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/python_scripts/orchestrator.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--data-dir",
        "${workspaceFolder}/data",
        "--output-dir",
        "${workspaceFolder}/outputs",
        "--skip-forecasting"
      ]
    }
  ]
}
